{
  "name": "@tanattv/lyt",
  "version": "0.7.2",
  "description": "Agent-ready local media CLI powered by yt-dlp and ffmpeg.",
  "type": "module",
  "bin": {
    "lyt": "./bin/lyt.js",
    "yt3": "./bin/yt3.js",
    "yt4": "./bin/yt4.js"
  },
  "scripts": {
    "test": "node --test",
    "check:pack": "node scripts/check-pack.js",
    "check:website": "npm --prefix website run check",
    "check": "npm test && npm run check:pack && npm run check:website",
    "smoke:linux": "bash scripts/smoke-linux.sh",
    "prepublishOnly": "npm run check"
  },
  "files": [
    "bin",
    "src",
    "skills",
    "schemas",
    "install",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanaTTV/lyt.git"
  },
  "homepage": "https://tanattv.github.io/lyt/",
  "bugs": {
    "url": "https://github.com/TanaTTV/lyt/issues"
  },
  "keywords": [
    "youtube",
    "yt-dlp",
    "ffmpeg",
    "download",
    "downloader",
    "audio",
    "video",
    "mp3",
    "cli",
    "ai-agent",
    "chatgpt",
    "codex",
    "claude",
    "claude-code",
    "gemini-cli",
    "llm-tools",
    "codex-cli",
    "local-first",
    "media-downloader"
  ],
  "license": "MIT"
}
