{
  "name": "@tanattv/lyt",
  "version": "0.7.0",
  "description": "Agent-ready local media CLI powered by yt-dlp and ffmpeg.",
  "type": "module",
  "bin": {
    "lyt": "./bin/lyt.js",
    "yt3": "./bin/yt3.js",
    "yt4": "./bin/yt4.js"
  },
  "scripts": {
    "test": "node --test",
    "check:pack": "node scripts/check-pack.js",
    "check": "npm test && npm run check:pack",
    "smoke:linux": "bash scripts/smoke-linux.sh",
    "prepublishOnly": "npm run check",
    "postinstall": "node -e \"console.log('\\nlyt installed. yt-dlp and ffmpeg are fetched automatically on first use.\\n  Check your setup any time with: lyt doctor\\n')\""
  },
  "files": [
    "bin",
    "src",
    "skills",
    "schemas",
    "install",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanaTTV/lyt.git"
  },
  "homepage": "https://github.com/TanaTTV/lyt#readme",
  "bugs": {
    "url": "https://github.com/TanaTTV/lyt/issues"
  },
  "keywords": [
    "youtube",
    "yt-dlp",
    "ffmpeg",
    "download",
    "downloader",
    "audio",
    "video",
    "mp3",
    "cli",
    "ai-agent",
    "codex",
    "claude"
  ],
  "license": "MIT"
}
