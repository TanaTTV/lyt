{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lyt",
  "version": "0.1.0",
  "identifier": "com.tanattv.lyt",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "windows": [
      {
        "title": "lyt",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; img-src 'self' asset: https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
