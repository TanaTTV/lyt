{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tanattv/lyt/blob/main/schemas/lyt.search.v1.schema.json",
  "title": "lyt search v1",
  "type": "object",
  "required": ["schema", "version", "command", "ok", "query", "limit", "total", "results"],
  "properties": {
    "schema": { "const": "lyt.search.v1" },
    "version": { "type": "string" },
    "command": { "const": "search" },
    "ok": { "const": true },
    "query": { "type": "string", "minLength": 1 },
    "limit": { "type": "integer", "minimum": 1, "maximum": 50 },
    "total": { "type": "integer", "minimum": 0 },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "url", "durationSeconds", "viewCount", "uploader", "channel", "thumbnail", "availability", "liveStatus"],
        "properties": {
          "id": { "type": ["string", "null"] },
          "title": { "type": ["string", "null"] },
          "url": { "type": ["string", "null"] },
          "durationSeconds": { "type": ["number", "null"] },
          "viewCount": { "type": ["number", "null"] },
          "uploader": { "type": ["string", "null"] },
          "channel": { "type": ["string", "null"] },
          "thumbnail": { "type": ["string", "null"] },
          "availability": { "type": ["string", "null"] },
          "liveStatus": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
